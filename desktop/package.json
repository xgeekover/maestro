{
  "name": "maestro-desktop",
  "version": "0.1.1",
  "description": "Maestro 데스크탑 앱 (Electron + React + Monaco + React Flow)",
  "author": "xgeekover",
  "repository": {
    "type": "git",
    "url": "https://github.com/xgeekover/maestro.git"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "fetch:jdtls": "node scripts/fetch-jdtls.mjs",
    "dist": "pnpm build && pnpm build:electron && electron-builder"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "monaco-editor": "^0.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "io.maestro.desktop",
    "productName": "Maestro",
    "publish": { "provider": "github", "owner": "xgeekover", "repo": "maestro" },
    "files": [
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": { "target": ["dmg", "zip"] },
    "win": { "target": ["nsis", "portable"] },
    "linux": { "target": "AppImage", "category": "Development" }
  }
}
